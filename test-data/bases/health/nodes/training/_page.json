{
  "layout": "grid",
  "gridColumns": 12,
  "modules": [
    {
      "id": "node-pdf-viewer",
      "type": "pdf-viewer",
      "title": "Lecture Notes",
      "position": {
        "x": 1,
        "y": 1,
        "width": 4,
        "height": 6
      },
      "config": {
        "filepath": "files/lecture-notes.pdf",
        "currentPage": 1,
        "zoom": 1
      }
    },
    {
      "id": "node-markdown-editor",
      "type": "markdown-editor",
      "title": "My Notes",
      "position": {
        "x": 5,
        "y": 1,
        "width": 4,
        "height": 6
      },
      "config": {
        "filepath": "files/notes.md",
        "autoSave": true
      }
    },
    {
      "id": "node-practice-bank",
      "type": "practice-bank",
      "title": "Practice Bank",
      "position": {
        "x": 9,
        "y": 1,
        "width": 4,
        "height": 6
      },
      "config": {
        "dataFile": "files/practice/questions.csv",
        "sortBy": "difficulty"
      }
    },
    {
      "id": "node-error-log",
      "type": "error-log",
      "title": "Error Log",
      "position": {
        "x": 1,
        "y": 7,
        "width": 6,
        "height": 4
      },
      "config": {
        "dataFile": "files/practice/error-log.json"
      }
    },
    {
      "id": "node-file-list",
      "type": "file-list",
      "title": "Files",
      "position": {
        "x": 7,
        "y": 13,
        "width": 6,
        "height": 4
      },
      "config": {
        "folder": "files"
      }
    }
  ],
  "templates": [
    "study-mode"
  ]
}