{
  "name": "synapse",
  "productName": "SYNAPSE",
  "version": "1.0.0",
  "description": "Desktop-first visual learning operating system",
  "main": "dist-electron/main/index.js",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "davids-labs",
    "email": "davoafo@gmail.com"
  },
  "scripts": {
    "dev": "node scripts/dev-runner.cjs",
    "synapse": "node scripts/run-synapse.cjs",
    "start:built": "node scripts/electron-runner.cjs dist-electron/main/index.js",
    "run": "npm run build && npm run start:built",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on http-get://127.0.0.1:5173 dist-electron/main/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --delay 400ms --watch dist-electron/main --watch dist-electron/shared --ext js --exec \"node scripts/electron-runner.cjs dist-electron/main/index.js\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "electron:build": "npm run build && electron-builder",
    "electron:build:dir": "npm run build && electron-builder --dir",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "generate:icons": "node scripts/generate-icons.cjs",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "chokidar": "3.5.3",
    "d3": "7.8.5",
    "d3-force": "3.0.0",
    "date-fns": "2.30.0",
    "framer-motion": "10.16.16",
    "gray-matter": "4.0.3",
    "katex": "0.16.9",
    "marked": "11.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "9.0.1",
    "react-pdf": "7.5.1",
    "react-router-dom": "6.30.1",
    "rehype-katex": "7.0.0",
    "remark-math": "6.0.0",
    "simple-git": "3.21.0",
    "zod": "3.22.4",
    "zustand": "4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "1.52.0",
    "@testing-library/react": "14.1.2",
    "@types/d3": "7.4.3",
    "@types/node": "20.11.10",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "@vitejs/plugin-react": "4.2.1",
    "autoprefixer": "10.4.16",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "electron": "28.0.0",
    "electron-builder": "24.9.1",
    "electron-updater": "6.6.2",
    "jsdom": "24.0.0",
    "nodemon": "3.1.10",
    "postcss": "8.4.32",
    "prettier": "^3.5.3",
    "sharp": "^0.33.5",
    "tailwindcss": "3.4.0",
    "typescript": "5.3.3",
    "vite": "5.0.8",
    "vitest": "1.0.4",
    "wait-on": "7.2.0"
  }
}
