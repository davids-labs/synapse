{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": "src",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/main/index.ts",
    "src/main/preload.ts",
    "src/main/bootstrapPaths.ts",
    "src/main/csvUtils.ts",
    "src/main/fileHelpers.ts",
    "src/main/fileWatcher.ts",
    "src/main/gitManager.ts",
    "src/main/hotDropManager.ts",
    "src/main/ipcHandlers.ts",
    "src/main/masteryEngine.ts",
    "src/main/starterWorkspace.ts",
    "src/main/updateManager.ts",
    "src/main/workspaceStore.ts",
    "src/shared/**/*"
  ]
}
